// Online Store Order Flow
graph "Order Processing" {

    // Simple nodes
    node start "Customer Visits"
    node browse "Browse Products"
    node cart "Shopping Cart"
    node payment "Payment Gateway"
    node review "Order Review"

    // Expanded nodes with styling
    node checkout {
        title: "Checkout"
        style {
            fill: true
            color: "#4CAF50"
            shape: circle
        }
    }

    node success {
        title: "Order Confirmed"
        style {
            fill: true
            color: "#2196F3"
        }
    }

    node declined "Payment Declined"
    node cancelled "Order Cancelled"
    node shipped "Shipped"
    node delivered "Delivered"
    node returned "Returned"

    // Simple chain - no labels
    start -> browse -> cart

    // Labeled chain
    cart -> "proceed" -> checkout -> "confirm" -> review
    review -> "pay" -> payment
    payment -> "success" -> success
    payment -> "declined" -> declined
    success -> shipped
    shipped -> delivered
    delivered -> "return" -> returned
    declined -> cancelled
}
